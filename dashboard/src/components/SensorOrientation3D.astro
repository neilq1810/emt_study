---
// 3-D sensor-orientation simulator (Ch. 13). Three.js scene: a field-generator
// triad and a tiltable/rollable sensor, with live measurement projections that
// make the 5-DOF roll null tangible in 3-D.
---
<div class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <div class="mb-3 flex flex-wrap items-center gap-4 text-sm">
    <label class="flex items-center gap-2">tilt:<input id="so-tilt" type="range" min="0" max="180" value="55" /><span id="so-tilt-v" class="tabular-nums">55°</span></label>
    <label class="flex items-center gap-2">azimuth:<input id="so-az" type="range" min="0" max="360" value="35" /><span id="so-az-v" class="tabular-nums">35°</span></label>
    <label class="flex items-center gap-2 font-semibold text-accent">roll:<input id="so-roll" type="range" min="0" max="360" value="0" /><span id="so-roll-v" class="tabular-nums">0°</span></label>
    <label class="flex items-center gap-2"><input id="so-2" type="checkbox" /> 2nd coil (6-DOF)</label>
  </div>
  <div class="flex flex-col gap-3 sm:flex-row">
    <canvas id="so-canvas" width="440" height="360" class="rounded bg-slate-900"></canvas>
    <div class="flex-1">
      <div id="so-bars" class="space-y-2 text-sm"></div>
      <p id="so-note" class="mt-2 text-sm"></p>
    </div>
  </div>
  <p class="mt-2 text-xs text-slate-400">
    Drag to orbit. Coloured rings = the generator triad; cyan arrow = sensor axis;
    r/g/b arrows = each transmit axis's field at the sensor. Move <b>roll</b>: the
    single coil's projections don't change (5-DOF null, Ch. 13 §13.1).
  </p>
</div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { dipoleField, type Vec3 } from '../lib/physics';

  const canvas = document.getElementById('so-canvas') as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setSize(440, 360, false);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0x0f172a);
  const camera = new THREE.PerspectiveCamera(45, 440 / 360, 0.01, 100);
  camera.position.set(0.55, 0.45, 0.7);
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping = true;
  scene.add(new THREE.AmbientLight(0xffffff, 0.8));
  const dl = new THREE.DirectionalLight(0xffffff, 0.6); dl.position.set(1, 1, 1); scene.add(dl);

  const COL = [0xef4444, 0x22c55e, 0x3b82f6]; // x, y, z transmit axes
  // generator triad: three rings in the coordinate planes
  const ringGeo = new THREE.TorusGeometry(0.06, 0.004, 12, 48);
  const planes: [number, number, number][] = [[0, Math.PI / 2, 0], [Math.PI / 2, 0, 0], [0, 0, 0]];
  planes.forEach((rot, i) => {
    const m = new THREE.Mesh(ringGeo, new THREE.MeshStandardMaterial({ color: COL[i] }));
    m.rotation.set(rot[0], rot[1], rot[2]); scene.add(m);
  });
  scene.add(new THREE.AxesHelper(0.12));

  const p: Vec3 = [0.28, 0.12, 0.24]; // sensor position [m]
  // sensor group: cylinder + a fin so roll is visible
  const sensor = new THREE.Group();
  sensor.position.set(p[0], p[1], p[2]);
  const body = new THREE.Mesh(new THREE.CylinderGeometry(0.012, 0.012, 0.07, 16),
    new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
  const fin = new THREE.Mesh(new THREE.BoxGeometry(0.006, 0.04, 0.022),
    new THREE.MeshStandardMaterial({ color: 0x06b6d4 }));
  fin.position.set(0.016, 0, 0);
  sensor.add(body); sensor.add(fin);
  scene.add(sensor);

  const axisArrow = new THREE.ArrowHelper(new THREE.Vector3(0, 1, 0), sensor.position, 0.11, 0x22d3ee, 0.025, 0.015);
  scene.add(axisArrow);
  const axis2Arrow = new THREE.ArrowHelper(new THREE.Vector3(1, 0, 0), sensor.position, 0.09, 0xa855f7, 0.022, 0.013);
  axis2Arrow.visible = false; scene.add(axis2Arrow);

  // field arrows (one per transmit axis) at the sensor
  const B = [dipoleField([1, 0, 0], p), dipoleField([0, 1, 0], p), dipoleField([0, 0, 1], p)];
  const bmax = Math.max(...B.map((b) => Math.hypot(b[0], b[1], b[2])));
  const fieldArrows = B.map((b, i) => {
    const v = new THREE.Vector3(b[0], b[1], b[2]).normalize();
    const len = 0.04 + 0.06 * (Math.hypot(b[0], b[1], b[2]) / bmax);
    const a = new THREE.ArrowHelper(v, sensor.position, len, COL[i], 0.018, 0.011);
    scene.add(a); return a;
  });

  const tilt = document.getElementById('so-tilt') as HTMLInputElement;
  const az = document.getElementById('so-az') as HTMLInputElement;
  const roll = document.getElementById('so-roll') as HTMLInputElement;
  const two = document.getElementById('so-2') as HTMLInputElement;
  const barsEl = document.getElementById('so-bars')!;
  const noteEl = document.getElementById('so-note')!;
  const yUp = new THREE.Vector3(0, 1, 0);

  function bar(label: string, val: number, color: string) {
    const w = Math.min(100, (val / bmax) * 100);
    return `<div><div class="flex justify-between text-xs text-slate-500"><span>${label}</span><span class="tabular-nums">${(val * 1e6).toFixed(2)} µT</span></div>
      <div class="h-3 w-full rounded bg-slate-100"><div class="h-3 rounded" style="width:${w}%;background:${color}"></div></div></div>`;
  }

  function update() {
    const th = (+tilt.value * Math.PI) / 180, ps = (+az.value * Math.PI) / 180, ph = (+roll.value * Math.PI) / 180;
    document.getElementById('so-tilt-v')!.textContent = tilt.value + '°';
    document.getElementById('so-az-v')!.textContent = az.value + '°';
    document.getElementById('so-roll-v')!.textContent = roll.value + '°';
    const n = new THREE.Vector3(Math.sin(th) * Math.cos(ps), Math.cos(th), Math.sin(th) * Math.sin(ps)).normalize();
    const qAlign = new THREE.Quaternion().setFromUnitVectors(yUp, n);
    const qRoll = new THREE.Quaternion().setFromAxisAngle(n, ph);
    sensor.quaternion.copy(qRoll.clone().multiply(qAlign));
    axisArrow.setDirection(n);
    const n2 = new THREE.Vector3(1, 0, 0).applyQuaternion(sensor.quaternion).normalize();
    axis2Arrow.setDirection(n2); axis2Arrow.visible = two.checked;

    const nv: Vec3 = [n.x, n.y, n.z], n2v: Vec3 = [n2.x, n2.y, n2.z];
    const dot = (a: Vec3, b: number[]) => Math.abs(a[0] * b[0] + a[1] * b[1] + a[2] * b[2]);
    let html = '<div class="font-medium">Coil 1 (sensor axis):</div>';
    ['Tx-x', 'Tx-y', 'Tx-z'].forEach((l, i) => (html += bar(l, dot(B[i] as any, nv), ['#ef4444', '#22c55e', '#3b82f6'][i])));
    if (two.checked) {
      html += '<div class="mt-2 font-medium">Coil 2 (⊥, rolls with sensor):</div>';
      ['Tx-x', 'Tx-y', 'Tx-z'].forEach((l, i) => (html += bar(l, dot(B[i] as any, n2v), '#a855f7')));
    }
    barsEl.innerHTML = html;
    noteEl.innerHTML = two.checked
      ? '<span class="text-violet-600">6-DOF:</span> coil-2 bars change with roll → roll observable.'
      : '<span class="text-accent">5-DOF:</span> rolling about the sensor axis leaves all three projections unchanged.';
  }
  [tilt, az, roll, two].forEach((e) => e.addEventListener('input', update));
  update();

  function animate() { requestAnimationFrame(animate); controls.update(); renderer.render(scene, camera); }
  animate();
</script>
