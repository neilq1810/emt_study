---
// System Design Dashboard (Ch. 8 eq. 8.1 + Ch. 12 trilemma + Ch. 31 capstone).
// Turn the design knobs (generator moment, sensor area-turns, excitation
// frequency, AFE noise, integration time, PDOP) and watch the whole system
// respond: field-referred noise σ_B, position accuracy across the volume, and
// the accuracy / rate / latency trilemma — all from the same physics library
// the Python suite is validated against.
---
<div class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <div class="grid grid-cols-1 gap-x-6 gap-y-2 sm:grid-cols-2 lg:grid-cols-3 text-sm">
    <label class="flex items-center justify-between gap-2">
      <span>moment m<sub>t</sub> [A·m²]</span>
      <span><input id="sd-m" type="range" min="0.5" max="10" step="0.5" value="1" /> <span id="sd-m-v" class="tabular-nums">1.0</span></span>
    </label>
    <label class="flex items-center justify-between gap-2">
      <span>area-turns N·A [×10⁻³ m²]</span>
      <span><input id="sd-na" type="range" min="0.1" max="20" step="0.1" value="0.2" /> <span id="sd-na-v" class="tabular-nums">0.2</span></span>
    </label>
    <label class="flex items-center justify-between gap-2">
      <span>frequency f [kHz]</span>
      <span><input id="sd-f" type="range" min="1" max="30" step="1" value="10" /> <span id="sd-f-v" class="tabular-nums">10</span></span>
    </label>
    <label class="flex items-center justify-between gap-2">
      <span>AFE noise e<sub>n</sub> [nV/√Hz]</span>
      <span><input id="sd-en" type="range" min="0.5" max="10" step="0.1" value="1.3" /> <span id="sd-en-v" class="tabular-nums">1.3</span></span>
    </label>
    <label class="flex items-center justify-between gap-2">
      <span>integration τ [ms]</span>
      <span><input id="sd-t" type="range" min="0.5" max="40" step="0.5" value="5" /> <span id="sd-t-v" class="tabular-nums">5.0</span></span>
    </label>
    <label class="flex items-center justify-between gap-2">
      <span>geometry PDOP</span>
      <span><input id="sd-p" type="range" min="1" max="5" step="0.1" value="1" /> <span id="sd-p-v" class="tabular-nums">1.0</span></span>
    </label>
  </div>

  <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div>
      <canvas id="sd-canvas" width="520" height="300" class="w-full max-w-[560px] rounded"></canvas>
      <p class="mt-1 text-xs text-slate-400">σ<sub>pos</sub> vs range (log mm). Markers at 0.2 / 0.3 / 0.5 m. Dashed = 1 mm spec.</p>
    </div>
    <div class="text-sm">
      <div class="rounded border border-slate-200 p-3">
        <div class="mb-1 font-medium text-slate-700">The trilemma (Ch. 12)</div>
        <div id="sd-tri" class="space-y-1"></div>
      </div>
      <div class="mt-3 rounded border border-slate-200 p-3">
        <div class="mb-1 font-medium text-slate-700">Link budget (Ch. 8 eq. 8.1)</div>
        <div id="sd-budget" class="space-y-1 text-xs text-slate-600"></div>
      </div>
      <p id="sd-verdict" class="mt-3 rounded p-2 text-sm font-medium"></p>
    </div>
  </div>
  <p class="mt-2 text-xs text-slate-400">
    σ<sub>B</sub> = e<sub>n</sub>√(ENBW)/(N·A·ω); σ<sub>pos</sub> = C·σ<sub>B</sub>·z⁴/m<sub>t</sub>·PDOP
    (Ch. 24 CRLB × geometry). Rate ≈ 1/(τ+overhead); latency ≈ τ + pipeline. All
    from <code>src/lib/physics.ts</code> (matches <code>simulations/emtrack</code>).
  </p>
</div>

<script>
  import { fieldReferredNoise, enbw, crlbPositionSigma } from '../lib/physics';

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const cv = $('sd-canvas') as unknown as HTMLCanvasElement;
  const ctx = cv.getContext('2d')!;
  const ctrls = {
    m: $('sd-m'), na: $('sd-na'), f: $('sd-f'), en: $('sd-en'), t: $('sd-t'), p: $('sd-p'),
  };
  const vals = {
    m: $('sd-m-v'), na: $('sd-na-v'), f: $('sd-f-v'), en: $('sd-en-v'), t: $('sd-t-v'), p: $('sd-p-v'),
  };
  const tri = document.getElementById('sd-tri')!;
  const budget = document.getElementById('sd-budget')!;
  const verdict = document.getElementById('sd-verdict')!;

  const padL = 52, padB = 34, padT = 12, padR = 12;
  const zMin = 0.1, zMax = 0.6, yMin = -3, yMax = 1;
  const px = (z: number) => padL + ((z - zMin) / (zMax - zMin)) * (cv.width - padL - padR);
  const py = (lm: number) => padT + (1 - (lm - yMin) / (yMax - yMin)) * (cv.height - padT - padB);

  // fixed pipeline latency beyond the integration window (Ch. 31 §31.6 budget)
  const PIPELINE_MS = 3.7; // decimation + DSP + solve + filter + transport
  const FRAME_OVERHEAD_MS = 1.0;

  function read() {
    return {
      m: Number(ctrls.m.value),
      na: Number(ctrls.na.value) * 1e-3,
      f: Number(ctrls.f.value) * 1e3,
      en: Number(ctrls.en.value) * 1e-9,
      tau: Number(ctrls.t.value) * 1e-3,
      pdop: Number(ctrls.p.value),
    };
  }

  function sigmaPos(z: number, p: ReturnType<typeof read>, sigmaB: number) {
    return crlbPositionSigma(z, sigmaB, p.m) * p.pdop;
  }

  function draw() {
    const p = read();
    const sigmaB = fieldReferredNoise(p.en, p.na, p.f, p.tau); // [T]
    ctx.clearRect(0, 0, cv.width, cv.height);

    // grid + labels
    ctx.strokeStyle = '#e2e8f0'; ctx.fillStyle = '#64748b'; ctx.font = '11px system-ui';
    for (let d = yMin; d <= yMax; d++) {
      const y = py(d);
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(cv.width - padR, y); ctx.stroke();
      ctx.fillText(`${Math.pow(10, d)} mm`.replace('0.001', '1 µm'), 4, y + 3);
    }
    for (let z = 0.1; z <= 0.6001; z += 0.1) ctx.fillText(z.toFixed(1), px(z) - 6, cv.height - 12);
    ctx.fillText('range z [m]', cv.width / 2 - 24, cv.height - 1);

    // 1 mm spec line
    ctx.strokeStyle = '#cbd5e1'; ctx.setLineDash([5, 4]);
    ctx.beginPath(); ctx.moveTo(padL, py(0)); ctx.lineTo(cv.width - padR, py(0)); ctx.stroke();
    ctx.setLineDash([]);

    // curve
    ctx.strokeStyle = '#0e7490'; ctx.lineWidth = 2.5; ctx.beginPath();
    for (let i = 0; i <= 200; i++) {
      const z = zMin + (i / 200) * (zMax - zMin);
      const mm = sigmaPos(z, p, sigmaB) * 1e3;
      const Y = py(Math.log10(Math.max(mm, 1e-4)));
      i === 0 ? ctx.moveTo(px(z), Y) : ctx.lineTo(px(z), Y);
    }
    ctx.stroke();

    // markers
    ctx.fillStyle = '#b91c1c';
    for (const z of [0.2, 0.3, 0.5]) {
      const mm = sigmaPos(z, p, sigmaB) * 1e3;
      ctx.beginPath(); ctx.arc(px(z), py(Math.log10(Math.max(mm, 1e-4))), 3, 0, 7); ctx.fill();
    }

    // trilemma readouts
    const rateHz = 1000 / (Number(ctrls.t.value) + FRAME_OVERHEAD_MS);
    const latMs = Number(ctrls.t.value) + PIPELINE_MS;
    const sFar = sigmaPos(0.5, p, sigmaB) * 1e3;
    tri.innerHTML =
      `<div>Accuracy (far, 0.5 m): <b class="tabular-nums">${sFar.toFixed(2)} mm</b></div>` +
      `<div>Update rate: <b class="tabular-nums">${rateHz.toFixed(0)} Hz</b> (τ=${ctrls.t.value} ms)</div>` +
      `<div>Latency: <b class="tabular-nums">${latMs.toFixed(1)} ms</b></div>`;

    budget.innerHTML =
      `σ_B = <b class="tabular-nums">${(sigmaB * 1e9).toFixed(2)} nT</b> ` +
      `(e_n=${ctrls.en.value} nV/√Hz, ENBW=${enbw(p.tau).toFixed(0)} Hz, N·A=${ctrls.na.value}e-3 m², f=${ctrls.f.value} kHz)`;

    // verdict against a 1 mm @ 0.5 m / 100 Hz / 20 ms target
    const okAcc = sFar <= 1.0, okRate = rateHz >= 100, okLat = latMs <= 20;
    const fails = [!okAcc && 'accuracy', !okRate && 'rate', !okLat && 'latency'].filter(Boolean);
    if (fails.length === 0) {
      verdict.textContent = '✓ Meets ≤1 mm @0.5 m, ≥100 Hz, ≤20 ms.';
      verdict.className = 'mt-3 rounded p-2 text-sm font-medium bg-emerald-50 text-emerald-700';
    } else {
      verdict.textContent = `✗ Misses: ${fails.join(', ')}. Trade against the trilemma (Ch. 12).`;
      verdict.className = 'mt-3 rounded p-2 text-sm font-medium bg-amber-50 text-amber-700';
    }
  }

  const fmt: Record<string, (v: string) => string> = {
    m: (v) => Number(v).toFixed(1), na: (v) => Number(v).toFixed(1), f: (v) => v,
    en: (v) => Number(v).toFixed(1), t: (v) => Number(v).toFixed(1), p: (v) => Number(v).toFixed(1),
  };
  for (const k of Object.keys(ctrls) as (keyof typeof ctrls)[]) {
    ctrls[k].addEventListener('input', () => { vals[k].textContent = fmt[k](ctrls[k].value); draw(); });
  }
  draw();
</script>
