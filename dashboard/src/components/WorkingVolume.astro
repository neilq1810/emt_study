---
// Working-volume optimizer (Ch. 9/24): the usable on-axis range where CRLB
// position uncertainty stays below an accuracy target.
---
<div class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <div class="mb-3 flex flex-wrap items-center gap-5 text-sm">
    <label class="flex items-center gap-2">moment [A·m²]:
      <input id="wv-m" type="range" min="0.5" max="20" step="0.5" value="1" />
      <span id="wv-m-val" class="tabular-nums">1.0</span></label>
    <label class="flex items-center gap-2">σ_B [nT]:
      <input id="wv-sb" type="range" min="0.1" max="10" step="0.1" value="1" />
      <span id="wv-sb-val" class="tabular-nums">1.0</span></label>
    <label class="flex items-center gap-2">target [mm]:
      <input id="wv-t" type="range" min="0.1" max="3" step="0.1" value="1" />
      <span id="wv-t-val" class="tabular-nums">1.0</span></label>
  </div>
  <canvas id="wv-canvas" width="520" height="300" class="w-full max-w-[560px] rounded"></canvas>
  <p id="wv-readout" class="mt-2 text-sm"></p>
  <p class="mt-1 text-xs text-slate-400">
    σ ∝ z⁴ means accuracy collapses fast with range; doubling the moment extends
    the usable radius only as the 4th root. (On-axis CRLB law from Ch. 24.)
  </p>
</div>

<script>
  import { crlbPositionSigma, crlbMaxRange } from '../lib/physics';

  const m = document.getElementById('wv-m') as HTMLInputElement;
  const sb = document.getElementById('wv-sb') as HTMLInputElement;
  const tg = document.getElementById('wv-t') as HTMLInputElement;
  const cv = document.getElementById('wv-canvas') as HTMLCanvasElement;
  const ctx = cv.getContext('2d')!;
  const readout = document.getElementById('wv-readout')!;

  const padL = 50, padB = 34, padT = 12, padR = 12;
  const zMax = 0.8, yMaxMm = 3;
  const px = (z: number) => padL + (z / zMax) * (cv.width - padL - padR);
  const py = (mm: number) => padT + (1 - Math.min(mm, yMaxMm) / yMaxMm) * (cv.height - padT - padB);

  function draw() {
    const moment = Number(m.value), sigmaB = Number(sb.value) * 1e-9, target = Number(tg.value);
    document.getElementById('wv-m-val')!.textContent = moment.toFixed(1);
    document.getElementById('wv-sb-val')!.textContent = Number(sb.value).toFixed(1);
    document.getElementById('wv-t-val')!.textContent = target.toFixed(1);
    const zmax = crlbMaxRange(target / 1000, sigmaB, moment);

    ctx.clearRect(0, 0, cv.width, cv.height);
    // usable region shading
    ctx.fillStyle = 'rgba(14,116,144,0.10)';
    ctx.fillRect(px(0), padT, px(Math.min(zmax, zMax)) - px(0), cv.height - padT - padB);
    // axes labels
    ctx.fillStyle = '#64748b'; ctx.font = '11px system-ui';
    for (let mm = 0; mm <= yMaxMm; mm++) { ctx.fillText(`${mm} mm`, 6, py(mm) + 3); }
    for (let z = 0; z <= zMax + 1e-9; z += 0.2) ctx.fillText(z.toFixed(1), px(z) - 6, cv.height - 12);
    ctx.fillText('range z [m]', cv.width / 2 - 24, cv.height - 1);
    // target line
    ctx.strokeStyle = '#ef4444'; ctx.setLineDash([5, 4]); ctx.beginPath();
    ctx.moveTo(px(0), py(target)); ctx.lineTo(px(zMax), py(target)); ctx.stroke();
    ctx.setLineDash([]);
    // sigma curve
    ctx.strokeStyle = '#0e7490'; ctx.lineWidth = 2.5; ctx.beginPath();
    for (let i = 0; i <= 200; i++) {
      const z = (i / 200) * zMax;
      const mm = crlbPositionSigma(z, sigmaB, moment) * 1e3;
      i === 0 ? ctx.moveTo(px(z), py(mm)) : ctx.lineTo(px(z), py(mm));
    }
    ctx.stroke();
    readout.innerHTML = `Usable on-axis range (σ < ${target.toFixed(1)} mm): <b>${(zmax * 100).toFixed(1)} cm</b> ` +
      `→ working-volume diameter ≈ <b>${(2 * zmax * 100).toFixed(0)} cm</b>`;
  }
  [m, sb, tg].forEach((e) => e.addEventListener('input', draw));
  draw();
</script>
