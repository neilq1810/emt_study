---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import type { PartGroup } from '../lib/toc';
import { chapterHref } from '../lib/toc';

interface Props {
  title: string;
  toc: PartGroup[];
  current?: string;
}

const { title, toc, current } = Astro.props;
const base = import.meta.env.BASE_URL;
const home = base.endsWith('/') ? base : base + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · EM-Tracking Definitive Guide</title>
    <meta
      name="description"
      content="A doctoral-level reference and engineering design guide for electromagnetic tracking (EMT)."
    />
  </head>
  <body>
    <div class="mx-auto flex max-w-[110rem]">
      <!-- Mobile nav backdrop -->
      <div id="nav-backdrop" class="fixed inset-0 z-30 hidden bg-slate-900/40 lg:hidden"></div>

      <!-- Sidebar (slide-in drawer on mobile, static on desktop) -->
      <aside
        id="sidebar"
        class="fixed inset-y-0 left-0 z-40 h-screen w-[18rem] max-w-[85vw] shrink-0 -translate-x-full overflow-y-auto border-r border-slate-200 bg-white px-5 py-6 transition-transform duration-200 lg:sticky lg:top-0 lg:z-auto lg:w-[var(--sidebar-w)] lg:max-w-none lg:translate-x-0"
      >
        <a href={home} class="block text-sm font-bold uppercase tracking-wide text-accent">
          EM-Tracking<br />Definitive Guide
        </a>
        <p class="mt-1 text-xs text-slate-500">Digital textbook · draft</p>
        <nav class="mt-5 text-sm">
          <h2 class="mb-1 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400">
            Simulations
          </h2>
          <ul class="mb-4 space-y-0.5">
            {[['results', 'Computed results'], ['figures', 'Figure gallery']].map(([path, label]) => (
              <li>
                <a class="block rounded px-2 py-1 text-slate-700 hover:bg-slate-100" href={home + path}>{label}</a>
              </li>
            ))}
          </ul>
          <h2 class="mb-1 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400">
            Dashboards
          </h2>
          <ul class="mb-4 space-y-0.5">
            {[
              ['dashboards/system-design', 'System-design dashboard'],
              ['dashboards/error-budget', 'Error-budget dashboard'],
              ['dashboards/clinical-accuracy', 'Clinical accuracy chain'],
              ['dashboards/distortion-compensation', 'Distortion & compensation'],
            ].map(([path, label]) => (
              <li>
                <a class="block rounded px-2 py-1 text-slate-700 hover:bg-slate-100" href={home + path}>{label}</a>
              </li>
            ))}
          </ul>
          <h2 class="mb-1 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400">
            Interactive tools
          </h2>
          <ul class="space-y-0.5">
            {
              [
                ['tools', 'All tools'],
                ['tools/dipole', 'Dipole field visualizer'],
                ['tools/coil-geometry', 'Coil-geometry explorer'],
                ['tools/dof', '5-DOF vs 6-DOF demo'],
                ['tools/sensor-orientation', 'Sensor orientation (3-D)'],
                ['tools/distortion', 'Distortion / eddy visualizer'],
                ['tools/skin-depth', 'Skin-depth & eddy explorer'],
                ['tools/lock-in', 'Lock-in simulator'],
                ['tools/noise-budget', 'Noise-budget calculator'],
                ['tools/snr-range', 'SNR vs distance'],
                ['tools/adc', 'ADC performance explorer'],
                ['tools/dsp-pipeline', 'DSP-pipeline visualizer'],
                ['tools/solver', 'Position-solver visualizer'],
                ['tools/kalman', 'Kalman-filter explorer'],
                ['tools/calibration', 'Calibration-workflow explorer'],
                ['tools/crlb', 'CRLB / accuracy explorer'],
                ['tools/error-propagation', 'Error-propagation simulator'],
                ['tools/monte-carlo', 'Monte-Carlo uncertainty'],
                ['tools/working-volume', 'Working-volume optimizer'],
                ['tools/patents', 'Patent / tech timeline'],
                ['tools/vendors', 'Vendor-ecosystem map'],
                ['tools/research', 'Research-landscape explorer'],
                ['tools/clinical', 'Clinical use-cases'],
              ].map(([path, label]) => (
                <li>
                  <a class="block rounded px-2 py-1 text-slate-700 hover:bg-slate-100" href={home + path}>
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <nav class="mt-6 space-y-5 text-sm">
          {
            toc.map((group) => (
              <div>
                <h2 class="mb-1 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400">
                  {group.label}
                </h2>
                <ul class="space-y-0.5">
                  {group.items.map((item) => (
                    <li>
                      <a
                        class="sidebar-link block rounded px-2 py-1 text-slate-700 hover:bg-slate-100"
                        href={chapterHref(base, item.id)}
                        aria-current={item.id === current ? 'page' : undefined}
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- Content -->
      <div class="min-w-0 flex-1">
        <header class="sticky top-0 z-20 flex items-center gap-3 border-b border-slate-200 bg-white/80 px-4 py-3 backdrop-blur lg:hidden">
          <button
            id="nav-toggle"
            type="button"
            aria-label="Open navigation"
            aria-expanded="false"
            class="-ml-1 rounded p-1.5 text-slate-700 hover:bg-slate-100"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
          <a href={home} class="text-sm font-bold text-accent">EM-Tracking Definitive Guide</a>
        </header>
        <main class="px-6 py-10 lg:px-12">
          <article class="prose prose-slate mx-auto max-w-prose prose-headings:scroll-mt-20 prose-pre:bg-slate-900 prose-pre:text-slate-100">
            <slot />
          </article>
        </main>
        <footer class="border-t border-slate-200 px-6 py-8 text-center text-xs text-slate-400">
          Generated from the <code>/book</code> manuscript · citations in
          <code>/citations/bibliography.json</code>. DRAFT — see ROADMAP for status.
        </footer>
      </div>
    </div>

    <script>
      const btn = document.getElementById('nav-toggle');
      const sb = document.getElementById('sidebar');
      const bd = document.getElementById('nav-backdrop');
      const isMobile = () => window.matchMedia('(max-width: 1023px)').matches;
      function openNav() {
        sb?.classList.remove('-translate-x-full');
        sb?.classList.add('translate-x-0');
        bd?.classList.remove('hidden');
        btn?.setAttribute('aria-expanded', 'true');
      }
      function closeNav() {
        sb?.classList.add('-translate-x-full');
        sb?.classList.remove('translate-x-0');
        bd?.classList.add('hidden');
        btn?.setAttribute('aria-expanded', 'false');
      }
      btn?.addEventListener('click', () =>
        sb?.classList.contains('-translate-x-full') ? openNav() : closeNav()
      );
      bd?.addEventListener('click', closeNav);
      // tapping a nav link on mobile closes the drawer
      sb?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => { if (isMobile()) closeNav(); })
      );
      // reset drawer state when crossing the breakpoint
      window.matchMedia('(min-width: 1024px)').addEventListener('change', closeNav);
    </script>
  </body>
</html>
