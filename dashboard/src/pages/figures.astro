---
import { getCollection } from 'astro:content';
import BookLayout from '../layouts/BookLayout.astro';
import { buildToc, chapterHref } from '../lib/toc';
import { FIGURES } from '../lib/simdata';

const toc = buildToc(await getCollection('book'));
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<BookLayout title="Figure gallery" toc={toc}>
  <h1>Figure gallery</h1>
  <p class="lead">
    Figures served from <code>/figures</code> — computed plots from
    <code>simulations/run_all.py</code> and schematic diagrams from
    <code>simulations/make_diagrams.py</code> — each linked to the chapter it backs
    and the computed <a href={b + 'results'}>results</a>.
  </p>

  <div class="not-prose grid gap-6 sm:grid-cols-2">
    {FIGURES.map((f) => (
      <figure class="rounded-lg border border-slate-200 bg-white p-3">
        <a href={b + 'figures/' + f.file} target="_blank" rel="noopener">
          <img src={b + 'figures/' + f.file} alt={f.title} loading="lazy"
               class="w-full rounded border border-slate-100" />
        </a>
        <figcaption class="mt-2">
          <div class="text-sm font-semibold">{f.title}</div>
          <div class="text-xs text-slate-500">{f.caption}</div>
          <a class="text-xs text-accent" href={chapterHref(base, f.chapterSlug)}>{f.chapter} →</a>
        </figcaption>
      </figure>
    ))}
  </div>
</BookLayout>
